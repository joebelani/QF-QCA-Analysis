<script>
const DEFS = [
  {type:'D', classes:'J,C',           pct:12, desc:'Business class'},
  {type:'D', classes:'Y,B,H,K',       pct:13, desc:'Economy flexible'},
  {type:'D', classes:'M,L,V,S,N,Q',   pct:7,  desc:'Economy restricted'},
  {type:'I', classes:'J,C',           pct:0,  desc:'Business class'},
  {type:'I', classes:'Y,B,H,K',       pct:0,  desc:'Economy flexible'},
  {type:'I', classes:'M,L,V,S,N,Q',   pct:0,  desc:'Economy restricted'},
];
let rates = JSON.parse(JSON.stringify(DEFS));
let aiFilled = false, cfgOpen = true, hasPdf = false, results = [], newCust = false;

function toggleNewCust() {
  newCust = !newCust;
  document.getElementById('custToggle').classList.toggle('active', newCust);
}

function buildMap(r) {
  const m = {D:{}, I:{}};
  r.forEach(x => x.classes.split(',').forEach(c => { m[x.type][c.trim()] = x.pct / 100; }));
  return m;
}

function renderRates() {
  document.getElementById('domR').innerHTML = '';
  document.getElementById('intR').innerHTML = '';
  rates.forEach((r, i) => {
    const def = DEFS[i];
    const cls = aiFilled && r.pct !== def.pct ? ' af' : r.pct !== def.pct ? ' mf' : '';
    const row = `<div class="dr">
      <span class="dc">${r.classes}</span>
      <span class="dd">${r.desc}</span>
      <div class="dp"><input class="pi${cls}" type="number" min="0" max="100" step="0.1" value="${r.pct}" data-i="${i}" oninput="upR(${i},this.value)" aria-label="${r.desc} discount %"> <small style="font-size:10px;color:var(--text3)">%</small></div>
    </div>`;
    document.getElementById(r.type === 'D' ? 'domR' : 'intR').innerHTML += row;
  });
  updMod();
}

function upR(i, v) {
  rates[i].pct = parseFloat(v) || 0;
  document.querySelectorAll('.pi').forEach(inp => {
    const j = parseInt(inp.dataset.i);
    inp.className = 'pi' + (aiFilled && rates[j].pct !== DEFS[j].pct ? ' af' : rates[j].pct !== DEFS[j].pct ? ' mf' : '');
  });
  updMod();
}

function updMod() {
  const any = rates.some((r, i) => r.pct !== DEFS[i].pct);
  document.getElementById('modPill').style.display = (!aiFilled && any) ? 'inline-flex' : 'none';
}

function resetR() {
  aiFilled = false; hasPdf = false;
  rates = JSON.parse(JSON.stringify(DEFS));
  renderRates();
  document.getElementById('aiPill').style.display = 'none';
  document.getElementById('ain').classList.remove('vis');
  document.getElementById('cfgSum').textContent = 'Default — Deal #18061389';
}

function togCfg() { /* panel always open */ }

// Drag & drop
function dov(e, id) { e.preventDefault(); document.getElementById(id).classList.add('drag'); }
function dlv(id) { document.getElementById(id).classList.remove('drag'); }
function ddr(e, id) {
  e.preventDefault(); dlv(id);
  const f = e.dataTransfer.files[0];
  if (!f) return;
  if (id === 'cz') onContract(f);
  else onData(f);
}

// ── CONTRACT PDF ──
async function onContract(file) {
  if (!file) return;
  const cz = document.getElementById('cz');
  cz.classList.add('has-file');
  cz.innerHTML = `<div class="uzone-inner"><div class="chip"><span>📄</span><span>${file.name}</span><span class="rx" onclick="clearC(event)">✕</span></div><div class="zh" style="margin-top:8px" id="czSub">Reading with AI...</div></div>`;
  setEbar(true, 'Reading contract with AI...', false);
  const reader = new FileReader();
  reader.onload = async e => {
    const b64 = e.target.result.split(',')[1];
    await extractRates(b64, file.name);
  };
  reader.readAsDataURL(file);
}

function clearC(e) {
  e.stopPropagation();
  hasPdf = false; resetR();
  const cz = document.getElementById('cz');
  cz.classList.remove('has-file');
