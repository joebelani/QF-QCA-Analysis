<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QF QCA Analysis</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    /* Corporate Traveller / TrAIlblazers brand palette */
    --brand-teal:   #00424E;
    --brand-pink:   #FE2E60;
    --brand-gold:   #FFCF6D;
    --brand-blue:   #96E6FF;
    --brand-lav:    #B5B1E3;
    --brand-softpk: #F3AEC0;

    --bg:    #ffffff;
    --bg2:   #F4F9FA;
    --bg3:   #E8F2F4;
    --text:  #00242C;
    --text2: #3A6470;
    --text3: #7DA5AE;
    --border:  rgba(0,66,78,0.12);
    --border2: rgba(0,66,78,0.28);

    --green:       #00424E;
    --green-light: #D6F0F4;
    --green-text:  #00424E;
    --blue-light:  #E0F8FF;
    --blue-text:   #005F7A;
    --amber-light: #FFF8E6;
    --amber-text:  #7A5A00;
    --red-light:   #FFF0F3;
    --red-text:    #9C0028;

    --radius: 8px; --radius-lg: 14px;
    --font: system-ui, -apple-system, 'Segoe UI', sans-serif;
    --mono: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
  }
  body { font-family: var(--font); background: linear-gradient(160deg, #E0F4F8 0%, #EDF8F4 40%, #F0F4FF 100%); background-attachment: fixed; color: var(--text); min-height: 100vh; }
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
  .page { max-width: 1100px; margin: 0 auto; padding: 1.5rem 1.5rem; }
  .hrow { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; margin-bottom: 1.5rem; }
  h1 { font-size: 22px; font-weight: 600; margin-bottom: 4px; }
  .sub { font-size: 14px; color: var(--text2); }
  .share-btn { display: flex; align-items: center; gap: 6px; padding: 8px 14px; font-size: 13px; border: 1px solid var(--border2); border-radius: var(--radius); background: var(--bg); color: var(--text); cursor: pointer; font-family: var(--font); white-space: nowrap; flex-shrink: 0; }
  .share-btn:hover { background: var(--bg2); }
  .toast { font-size: 12px; color: var(--green-text); margin-top: 4px; text-align: right; min-height: 16px; }

  /* Tabs */
  .tabs { display: flex; border-bottom: 2px solid var(--border); margin-bottom: 1.5rem; background: var(--bg); border-radius: var(--radius-lg) var(--radius-lg) 0 0; padding: 0 4px; }
  .tab { padding: 12px 20px; font-size: 14px; background: none; border: none; border-bottom: 2px solid transparent; cursor: pointer; color: var(--text2); font-family: var(--font); margin-bottom: -2px; transition: all .2s; border-radius: var(--radius-lg) var(--radius-lg) 0 0; }
  .tab:hover { color: var(--brand-teal); background: var(--bg2); }
  .tab.active { color: var(--brand-teal); border-bottom-color: var(--brand-pink); font-weight: 600; }
  .panel { display: none; } .panel.active { display: block; }

  /* Card */
  .card { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); margin-bottom: 1.25rem; overflow: hidden; border-top: 3px solid var(--brand-pink); box-shadow: 0 2px 12px rgba(0,66,78,0.07); }

  /* Upload zones */
  .upload-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 1.25rem; }
  @media(max-width:540px){ .upload-row { grid-template-columns: 1fr; } }
  .slabel { font-size: 11px; font-weight: 700; color: var(--brand-teal); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 8px; display: flex; align-items: center; gap: 5px; }
  .uzone {
    background: linear-gradient(145deg, #ffffff 0%, #f0fafc 100%);
    border: 2px dashed rgba(0,66,78,0.2);
    border-radius: 18px;
    padding: 0;
    text-align: center;
    cursor: pointer;
    transition: all .25s cubic-bezier(.34,1.56,.64,1);
    position: relative;
    min-height: 190px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,66,78,0.06);
  }
  .uzone::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,66,78,0.03) 0%, rgba(254,46,96,0.04) 100%);
    opacity: 0;
    transition: opacity .25s;
  }
  .uzone:hover::before, .uzone.drag::before { opacity: 1; }
  .uzone:hover, .uzone.drag {
    border-color: var(--brand-teal);
    border-style: solid;
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(0,66,78,0.14);
  }
  .uzone.has-file {
    border-style: solid;
    border-color: var(--brand-teal);
    background: linear-gradient(145deg, #f0fafc 0%, #e0f8ff 100%);
  }
  .uzone input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; z-index: 2; }
  .uzone-inner { display: flex; flex-direction: column; align-items: center; gap: 10px; padding: 1.5rem 1.25rem; z-index: 1; }
  .uzone-icon { width: 64px; height: 64px; display: flex; align-items: center; justify-content: center; border-radius: 16px; margin-bottom: 4px; }
  .uzone-icon svg { width: 44px; height: 44px; }
  .uzone .zt { font-size: 14px; font-weight: 700; color: var(--text); letter-spacing: -0.2px; }
  .uzone .zh { font-size: 12px; color: var(--text3); line-height: 1.5; max-width: 200px; }
  .uzone-badge { display: inline-flex; align-items: center; gap: 4px; font-size: 10px; font-weight: 700; padding: 3px 10px; border-radius: 100px; text-transform: uppercase; letter-spacing: .05em; margin-top: 4px; }
  .chip { display: inline-flex; align-items: center; gap: 6px; background: white; border: 1.5px solid var(--border); border-radius: 100px; padding: 5px 14px; font-size: 12px; font-weight: 600; max-width: 220px; box-shadow: 0 2px 8px rgba(0,66,78,0.08); }
  .chip span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--brand-teal); }
  .chip .rx { cursor: pointer; color: var(--text3); margin-left: 4px; font-size: 15px; line-height: 1; font-weight: 700; }
  .chip .rx:hover { color: var(--brand-pink); }
  @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
  @keyframes pulse-ring { 0%{transform:scale(1);opacity:.6} 100%{transform:scale(1.4);opacity:0} }
  .float-anim { animation: float 3s ease-in-out infinite; }

  /* Extraction bar */
  .ebar { display: none; align-items: center; gap: 10px; background: var(--bg2); border-radius: var(--radius); padding: 10px 14px; margin-bottom: 1.25rem; font-size: 13px; color: var(--text2); }
  .ebar.vis { display: flex; }
  .spin { width: 16px; height: 16px; border: 2px solid var(--border2); border-top-color: var(--green); border-radius: 50%; animation: sp .7s linear infinite; flex-shrink: 0; }
  @keyframes sp { to { transform: rotate(360deg); } }

  /* Config */
  .cfgh { display: flex; align-items: center; justify-content: space-between; padding: 11px 16px; background: var(--bg2); border-bottom: 1px solid var(--border); cursor: pointer; user-select: none; transition: background .15s; }
  .cfgh-l { display: flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; }
  .cfgh-l small { font-size: 12px; color: var(--text3); font-weight: 400; margin-left: 4px; }
  .cfgh-r { display: flex; align-items: center; gap: 6px; }
  .pill { display: inline-flex; align-items: center; gap: 3px; font-size: 11px; padding: 2px 9px; border-radius: 100px; font-weight: 600; }
  .pill-g { background: var(--brand-teal); color: #fff; }
  .pill-a { background: var(--brand-gold); color: var(--brand-teal); }
  .chev { font-size: 18px; color: var(--text3); transition: transform .2s; display: inline-block; }
  .chev.open { transform: rotate(180deg); }
  .cfgb { display: none; padding: 16px; }
  .cfgb.open { display: block; }
  .ai-note { display: none; font-size: 13px; color: var(--green-text); background: var(--green-light); border-radius: var(--radius); padding: 9px 13px; margin-bottom: 14px; line-height: 1.5; }
  .ai-note.vis { display: block; }
  .cfg-intro { font-size: 13px; color: var(--text2); margin-bottom: 12px; line-height: 1.6; }
  .dg { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media(max-width:500px){ .dg { grid-template-columns: 1fr; } }
  .ds { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .dsh { padding: 8px 12px; background: var(--bg2); font-size: 11px; font-weight: 600; color: var(--text2); border-bottom: 1px solid var(--border); text-transform: uppercase; letter-spacing: .04em; }
  .dr { display: grid; grid-template-columns: auto 1fr 72px; align-items: center; border-bottom: 1px solid var(--border); }
  .dr:last-child { border-bottom: none; }
  .dr .dc { padding: 7px 10px; font-family: var(--mono); font-size: 12px; }
  .dr .dd { padding: 7px 6px; font-size: 12px; color: var(--text2); }
  .dr .dp { padding: 5px 8px; }
  .pi { width: 62px; padding: 5px 8px; font-size: 13px; font-family: var(--mono); text-align: right; border: 1px solid var(--border2); border-radius: var(--radius); background: var(--bg); color: var(--text); }
  .pi:focus { outline: none; border-color: var(--green); }
  .pi.af { border-color: var(--green); color: var(--green-text); font-weight: 600; }
  .pi.mf { border-color: var(--amber-text); color: var(--amber-text); font-weight: 600; }
  .ca { margin-top: 12px; }
  .rbtn { padding: 6px 14px; font-size: 13px; border: 1.5px solid var(--border2); border-radius: var(--radius); background: none; color: var(--text2); cursor: pointer; font-family: var(--font); transition: all .15s; }
  .rbtn:hover { background: var(--bg2); color: var(--text); }

  /* Run */
  .pbar { height: 3px; background: var(--bg3); border-radius: 2px; margin-top: 12px; display: none; overflow: hidden; }
  .pfill { height: 100%; width: 0%; background: var(--brand-pink); border-radius: 2px; transition: width .3s; }
  .run-row { display: flex; align-items: center; gap: 14px; margin-top: 1.25rem; flex-wrap: wrap; }
  .runbtn { display: flex; align-items: center; gap: 8px; background: var(--brand-pink); color: #fff; border: none; padding: 11px 22px; border-radius: var(--radius); font-size: 14px; font-weight: 600; cursor: pointer; font-family: var(--font); transition: opacity .15s; letter-spacing: 0.2px; }
  .runbtn:hover { opacity: .88; } .runbtn:disabled { opacity: .4; cursor: not-allowed; }
  .st { font-size: 13px; color: var(--text2); } .st.ok { color: var(--green-text); } .st.er { color: var(--red-text); }

  /* Results */
  .mets { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 10px; margin-bottom: 1.25rem; }
  .met { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1rem 1.1rem; border-left: 4px solid var(--brand-pink); box-shadow: 0 2px 8px rgba(0,66,78,0.06); transition: transform .2s, box-shadow .2s; } .met:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0,66,78,0.12); }
  .ml { font-size: 11px; color: var(--brand-teal); margin-bottom: 5px; text-transform: uppercase; letter-spacing: .04em; font-weight: 700; }
  .mv { font-size: 22px; font-weight: 700; }
  .ms { font-size: 11px; color: var(--text3); margin-top: 2px; }
  .tc { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem; }
  @media(max-width:520px){ .tc { grid-template-columns: 1fr; } }
  .stitle { font-size: 13px; font-weight: 700; margin-bottom: 10px; color: var(--brand-teal); text-transform: uppercase; letter-spacing: .04em; }
  .cbr { display: flex; align-items: center; gap: 8px; margin-bottom: 7px; }
  .cbl { font-size: 11px; color: var(--text2); width: 100px; text-align: right; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .cbt { flex: 1; height: 20px; background: var(--bg3); border-radius: 4px; overflow: hidden; }
  .cbf { height: 100%; border-radius: 4px; min-width: 2px; display: flex; align-items: center; padding-left: 6px; }
  .cbv { font-size: 10px; color: #fff; white-space: nowrap; font-weight: 600; }
  .fils { display: flex; gap: 8px; margin-bottom: .75rem; flex-wrap: wrap; align-items: center; }
  .fsel { padding: 7px 10px; font-size: 13px; border: 1px solid var(--border2); border-radius: var(--radius); background: var(--bg); color: var(--text); font-family: var(--font); }
  .expbtn { display: flex; align-items: center; gap: 6px; padding: 8px 16px; font-size: 13px; border: 1.5px solid var(--brand-teal); border-radius: var(--radius); background: var(--bg); color: var(--brand-teal); cursor: pointer; font-family: var(--font); font-weight: 600; margin-left: auto; transition: all .15s; }
  .expbtn:hover { background: var(--brand-teal); color: #fff; }
  .export-modal { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center; padding: 1rem; }
  .export-modal.vis { display: flex; }
  .export-modal-inner { background: var(--bg); border-radius: var(--radius-lg); padding: 1.5rem; width: 100%; max-width: 680px; max-height: 80vh; display: flex; flex-direction: column; gap: 1rem; box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
  .export-modal-header { display: flex; align-items: center; justify-content: space-between; }
  .export-modal-header h2 { font-size: 16px; font-weight: 700; color: var(--brand-teal); }
  .export-close { background: none; border: none; font-size: 22px; cursor: pointer; color: var(--text3); line-height: 1; padding: 0 4px; }
  .export-close:hover { color: var(--text); }
  .export-instructions { font-size: 13px; color: var(--text2); line-height: 1.5; }
  .export-textarea { width: 100%; flex: 1; min-height: 260px; font-family: var(--mono); font-size: 11px; padding: 10px; border: 1px solid var(--border2); border-radius: var(--radius); background: var(--bg2); color: var(--text); resize: none; }
  .export-actions { display: flex; gap: 8px; }
  .copy-btn { display: flex; align-items: center; gap: 6px; padding: 9px 18px; font-size: 13px; font-weight: 700; background: var(--brand-pink); color: #fff; border: none; border-radius: var(--radius); cursor: pointer; font-family: var(--font); transition: opacity .15s; }
  .copy-btn:hover { opacity: .88; }
  .copy-note { font-size: 12px; color: var(--text3); align-self: center; }
  .tw { overflow-x: auto; border: 1px solid var(--border); border-radius: var(--radius-lg); }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { padding: 10px 14px; text-align: left; font-weight: 600; font-size: 11px; color: var(--brand-teal); border-bottom: 2px solid var(--brand-pink); background: var(--bg2); white-space: nowrap; text-transform: uppercase; letter-spacing: .04em; }
  td { padding: 9px 14px; border-bottom: 1px solid var(--border); white-space: nowrap; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: var(--bg2); }
  .bg { display: inline-block; padding: 2px 8px; border-radius: 100px; font-size: 11px; font-weight: 600; }
  .bg-qf { background: var(--blue-light); color: var(--blue-text); }
  .bg-ec { background: #EAF3DE; color: #3B6D11; }
  .bg-bz { background: var(--amber-light); color: var(--amber-text); }
  .sp { color: var(--brand-teal); font-weight: 600; } .sn { color: var(--brand-pink); font-weight: 600; }
  .rcount { font-size: 12px; color: var(--text3); margin-top: 8px; }
  .empty { text-align: center; padding: 3rem; color: var(--text3); font-size: 14px; }
  .empty .ei { font-size: 36px; display: block; margin-bottom: 10px; }

  /* How it works */
  .hwg { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 1.25rem; }
  @media(max-width:500px){ .hwg { grid-template-columns: 1fr; } }
  .hwc { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 1.25rem; box-shadow: 0 2px 8px rgba(0,66,78,0.06); transition: transform .2s; } .hwc:hover { transform: translateY(-2px); }
  .hwc .hi { font-size: 22px; display: block; margin-bottom: 8px; }
  .hwc p { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
  .hwc small { font-size: 12px; color: var(--text2); line-height: 1.5; display: block; }
  .it { border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; margin-bottom: 1.25rem; }
  .it table { font-size: 13px; }
  .enc-warn { display: none; background: #FCEBEB; border: 1px solid #F09595; border-radius: var(--radius-lg); padding: 1rem 1.25rem; margin-bottom: 1.25rem; }
  .enc-warn.vis { display: block; }
  .enc-warn-title { font-size: 14px; font-weight: 600; color: #501313; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
  .enc-warn p { font-size: 13px; color: #791F1F; margin-bottom: 10px; line-height: 1.6; }
  .enc-steps { list-style: none; counter-reset: steps; }
  .enc-steps li { counter-increment: steps; display: flex; align-items: flex-start; gap: 10px; font-size: 13px; color: #791F1F; margin-bottom: 7px; line-height: 1.5; }
  .enc-steps li::before { content: counter(steps); background: #F7C1C1; color: #501313; border-radius: 50%; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; flex-shrink: 0; margin-top: 1px; }
  .enc-steps code { background: #F7C1C1; padding: 1px 6px; border-radius: 4px; font-family: var(--mono); font-size: 12px; }
  @media (prefers-color-scheme: dark) {
    .enc-warn { background: #2a0e0e; border-color: #791F1F; }
    .enc-warn-title { color: #F09595; }
    .enc-warn p, .enc-steps li { color: #F7C1C1; }
    .enc-steps li::before { background: #501313; color: #F7C1C1; }
    .enc-steps code { background: #501313; color: #F09595; }
  }
  .data-hint { font-size: 12px; color: var(--text3); margin-top: 6px; display: flex; align-items: center; gap: 4px; }
  .cust-toggle { display: flex; align-items: center; gap: 14px; background: var(--bg); border: 2px solid var(--border2); border-radius: var(--radius-lg); padding: 14px 18px; margin-bottom: 1.25rem; cursor: pointer; transition: all .2s; user-select: none; }
  .cust-toggle:hover { border-color: var(--brand-pink); background: var(--red-light); }
  .cust-toggle.active { border-color: var(--brand-pink); background: var(--red-light); }
  .cust-toggle-check { width: 22px; height: 22px; border-radius: 50%; border: 2.5px solid var(--border2); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all .2s; font-size: 13px; color: transparent; }
  .cust-toggle.active .cust-toggle-check { background: var(--brand-pink); border-color: var(--brand-pink); color: #fff; }
  .cust-toggle-text strong { font-size: 14px; font-weight: 700; color: var(--brand-teal); display: block; margin-bottom: 2px; }
  .cust-toggle.active .cust-toggle-text strong { color: var(--brand-pink); }
  .cust-toggle-text span { font-size: 12px; color: var(--text2); line-height: 1.4; }
</style>
</head>
<body>
<div class="page">

  <!-- Branded header -->
  <div style="background:var(--brand-teal);border-radius:20px;margin-bottom:1.5rem;overflow:hidden;position:relative;">

    <!-- Animated background planes -->
    <svg style="position:absolute;inset:0;width:100%;height:100%;opacity:0.07;pointer-events:none" viewBox="0 0 1100 160" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Flight path arcs -->
      <path d="M-50 120 Q200 20 500 80 Q800 140 1150 40" stroke="white" stroke-width="1.5" fill="none" stroke-dasharray="6 4"/>
      <path d="M-50 60 Q300 130 600 50 Q900 -20 1150 90" stroke="white" stroke-width="1" fill="none" stroke-dasharray="4 6"/>
      <!-- Planes -->
      <g transform="translate(160,58) rotate(-18)"><path d="M0 4 L14 0 L11 4 L14 8 Z" fill="white"/><path d="M3 2 L3 6 L-4 7 L-4 1 Z" fill="white" opacity=".7"/></g>
      <g transform="translate(480,72) rotate(-8)"><path d="M0 3 L10 0 L8 3 L10 6 Z" fill="white"/><path d="M2 1.5 L2 4.5 L-3 5 L-3 1 Z" fill="white" opacity=".6"/></g>
      <g transform="translate(820,52) rotate(-22)"><path d="M0 4 L14 0 L11 4 L14 8 Z" fill="white"/><path d="M3 2 L3 6 L-4 7 L-4 1 Z" fill="white" opacity=".7"/></g>
      <g transform="translate(1020,88) rotate(-12)"><path d="M0 3 L10 0 L8 3 L10 6 Z" fill="white"/><path d="M2 1.5 L2 4.5 L-3 5 L-3 1 Z" fill="white" opacity=".5"/></g>
      <!-- Stars / dots -->
      <circle cx="80" cy="30" r="1.5" fill="white"/><circle cx="250" cy="140" r="1" fill="white"/>
      <circle cx="600" cy="20" r="1.5" fill="white"/><circle cx="750" cy="130" r="1" fill="white"/>
      <circle cx="950" cy="35" r="1.5" fill="white"/><circle cx="1050" cy="120" r="1" fill="white"/>
    </svg>

    <div style="position:relative;z-index:1;padding:1.5rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;">

      <!-- Left: logo + title -->
      <div style="display:flex;align-items:center;gap:1.5rem;">
        <div style="position:relative;flex-shrink:0;">
          <!-- Glowing ring behind logo -->
          <div style="position:absolute;inset:-6px;border-radius:20px;background:rgba(255,207,109,0.25);filter:blur(8px);"></div>
          <img src="data:image/png;base64," alt="TrAIlblazers logo" style="height:80px;width:auto;border-radius:14px;position:relative;z-index:1;box-shadow:0 4px 20px rgba(0,0,0,0.3);">
