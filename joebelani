  setEbar(false);
}

async function extractRates(b64, fname) {
  const prompt = `Extract airline fare class discount rates from this contract PDF.

Find booking class codes (like J, C, Y, B, H, K, M, L, V, S, N, Q) and their discount percentages for Qantas (QF) flights.
Identify domestic (D) vs international (I) rates separately if present.
Also extract the contract or deal number/name if visible.

Reply ONLY with this JSON (no markdown, no explanation):
{"contractName":"Deal #XXXXX or name here","notes":"one sentence describing what was found","rates":[{"type":"D","classes":"J,C","pct":12,"desc":"Business class"},{"type":"D","classes":"Y,B,H,K","pct":13,"desc":"Economy flexible"},{"type":"D","classes":"M,L,V,S,N,Q","pct":7,"desc":"Economy restricted"},{"type":"I","classes":"J,C","pct":0,"desc":"Business class"},{"type":"I","classes":"Y,B,H,K","pct":0,"desc":"Economy flexible"},{"type":"I","classes":"M,L,V,S,N,Q","pct":0,"desc":"Economy restricted"}]}

Always return exactly 6 rate rows (3 domestic, 3 international). If a rate is not found in the contract, keep the default value shown above.`;

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{
          role: 'user',
          content: [
            { type: 'document', source: { type: 'base64', media_type: 'application/pdf', data: b64 } },
            { type: 'text', text: prompt }
          ]
        }]
      })
    });
    const data = await resp.json();
    const txt = data.content?.find(b => b.type === 'text')?.text || '';
    const parsed = JSON.parse(txt.replace(/```json|```/g, '').trim());
    if (parsed.rates?.length === 6) {
      rates = parsed.rates;
      aiFilled = true; hasPdf = true;
      renderRates();
      document.getElementById('aiPill').style.display = 'inline-flex';
      document.getElementById('cfgSum').textContent = parsed.contractName || 'AI extracted';
      document.getElementById('ainTxt').textContent = parsed.notes || `Rates extracted from ${fname}`;
      document.getElementById('ain').classList.add('vis');
      setEbar(true, `✅ Rates extracted from "${fname}"`, true);
      const sub = document.getElementById('czSub');
      if (sub) sub.textContent = 'Rates applied ✓';
      if (!cfgOpen) togCfg();
    } else {
      throw new Error('Unexpected response');
    }
  } catch (err) {
    setEbar(false);
    const sub = document.getElementById('czSub');
    if (sub) sub.textContent = 'Could not extract — you can edit rates manually below';
    console.error('Extraction error:', err);
  }
}

function setEbar(vis, msg, done) {
  const b = document.getElementById('ebar');
  b.classList.toggle('vis', vis);
  if (vis) {
    document.getElementById('emsg').textContent = msg || '';
    document.getElementById('espin').style.display = done ? 'none' : 'block';
    document.getElementById('edone').style.display = done ? 'inline' : 'none';
  }
}

// ── DATA FILE ──
function onData(file) {
  if (!file) return;
  document.getElementById('encWarn').classList.remove('vis');
  const dz = document.getElementById('dz');
  dz.classList.add('has-file');
  dz.innerHTML = `<div class="uzone-inner"><div class="chip"><span>📊</span><span>${file.name}</span><span class="rx" onclick="clearD(event)">✕</span></div><div class="zh" style="margin-top:8px" id="dzSub">Reading...</div></div>`;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const wb = XLSX.read(e.target.result, { type: 'array', cellDates: true });
      const ws = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(ws, { defval: '' });
      const sub = document.getElementById('dzSub');
      if (sub) sub.textContent = `${rows.length.toLocaleString()} rows ready`;
      window._rows = rows;
      document.getElementById('runBtn').disabled = false;
      setSt('Ready to run.', '');
    } catch (err) {
      const isEncrypted = err.message && (
        err.message.includes('Encrypted') ||
        err.message.includes('EncryptionInfo') ||
        err.message.includes('password') ||
        err.message.includes('ECMA-376')
      );
      if (isEncrypted) {
        document.getElementById('encWarn').classList.add('vis');
        const sub = document.getElementById('dzSub');
        if (sub) sub.textContent = '🔒 File is password protected';
        setSt('Remove the password in Excel first — see the instructions below.', 'er');
      } else {
        setSt('Could not read file: ' + err.message, 'er');
      }
    }
  };
  reader.readAsArrayBuffer(file);
}

function clearD(e) {
  e.stopPropagation(); window._rows = null;
  document.getElementById('encWarn').classList.remove('vis');
  document.getElementById('runBtn').disabled = true;
  const dz = document.getElementById('dz');
  dz.classList.remove('has-file');
  dz.innerHTML = `<input type="file" id="dInput" accept=".xlsx,.xls,.csv" onchange="onData(this.files[0])"><div class="uzone-inner"><div class="uzone-icon" style="background:linear-gradient(135deg,#E0F8FF,#C8F0FA);"><svg viewBox="0 0 44 44" fill="none" class="float-anim" style="animation-delay:.4s"><rect x="7" y="8" width="26" height="30" rx="3" fill="#00424E"/><rect x="9" y="10" width="22" height="26" rx="2" fill="white"/><rect x="9" y="10" width="22" height="5" rx="2" fill="#96E6FF"/><line x1="16" y1="10" x2="16" y2="36" stroke="#E0F8FF" stroke-width=".8"/><line x1="23" y1="10" x2="23" y2="36" stroke="#E0F8FF" stroke-width=".8"/><line x1="9" y1="20" x2="31" y2="20" stroke="#E0F8FF" stroke-width=".8"/><line x1="9" y1="25" x2="31" y2="25" stroke="#E0F8FF" stroke-width=".8"/><line x1="9" y1="30" x2="31" y2="30" stroke="#E0F8FF" stroke-width=".8"/><rect x="24" y="21.5" width="5" height="2" rx="1" fill="#FE2E60" opacity=".5"/><rect x="24" y="26.5" width="5" height="2" rx="1" fill="#FE2E60" opacity=".5"/><rect x="24" y="31.5" width="5" height="2" rx="1" fill="#FE2E60" opacity=".5"/><g transform="translate(28,4) rotate(-30)"><path d="M0 3 L8 0 L6 3 L8 6 Z" fill="#FFCF6D"/></g></svg></div><div class="zt">Drop segment data export</div><div class="zh">Segment Raw Data Report — export as CSV (no password)</div><span class="uzone-badge" style="background:#E0F8FF;color:#005F7A;">CSV or Excel</span></div>`;
  setSt('', '');
}

// ── ANALYSIS ──
function runAnalysis() {
  const rows = window._rows; if (!rows) return;
  // Reset to defaults only if no PDF uploaded AND no manual edits made
  const manuallyEdited = rates.some((r, i) => r.pct !== DEFS[i].pct);
  if (!hasPdf && !manuallyEdited) { rates = JSON.parse(JSON.stringify(DEFS)); aiFilled = false; renderRates(); document.getElementById('aiPill').style.display = 'none'; }
  const btn = document.getElementById('runBtn'); btn.disabled = true;
  const pb = document.getElementById('pb'), pf = document.getElementById('pf');
  pb.style.display = 'block'; pf.style.width = '15%';
  setTimeout(() => {
    try {
      pf.style.width = '60%';
      const map = buildMap(rates), res = [];
      const parseVal = v => parseFloat((v || '0').toString().replace(/\s/g, '')) || 0;
      rows.forEach(row => {
        const al = (row['Airline Designator'] || row['Provider Code'] || row['DimCabinClass_provider_code_'] || '').toString().trim().toUpperCase();
        const tt = (row['Ticket Type'] || row['FactSalesSegmentCustomer_ticket_type_'] || '').toString().trim();
        if (al !== 'QF' || tt !== 'Original Ticket') return;
        const tv = (row['Booking INT DOM TT'] || row['Travel Type  Group '] || row['Travel Type'] || row['DimDomInt_booking_int_flag_'] || '').toString().trim().toUpperCase().charAt(0);
        const bc = (row['Booking Class '] || row['Booking Class'] || row['DimCabinClass_class_code_'] || '').toString().trim().toUpperCase();
        const tax = parseVal(row['Total Tax'] || row['ID_tax_local_']);
        const ttv = parseVal(row['TTV excl gst '] || row['TTV excl gst'] || row['ID_segment_ttv_excl_gst_']);
        const trav = (row['Booking Name '] || row['Booking Name'] || row['DimBooking_booking_name_'] || '').toString().trim();
        const route = (row['Iata City Pair'] || row['DimCityPair_iata_city_pair_'] || '').toString().trim();
        const cabin = (row['Cabin Class'] || row['DimCabinClass_class_name_'] || '').toString().trim();
        const gst = tax / 100 * 10, gross = ttv - gst;
        const disc = (map[tv] || {})[bc] || 0;
        // New customer mode: savings = gross fare × discount (discount off what they paid)
        // Existing contract mode: savings = original fare − gross fare (uplift then diff)
        const orig = newCust ? gross : gross * (1 + disc);
        const sav  = newCust ? gross * disc : orig - gross;
        res.push({ al, trav, route, cabin, bc, tv, gross, disc, orig, sav, gst });
      });
      pf.style.width = '100%'; results = res;
      setTimeout(() => {
        pb.style.display = 'none'; btn.disabled = false;
        setSt(`Done — ${res.length.toLocaleString()} QF original ticket segments processed.`, 'ok');
        buildResults(res); goTabDirect('results');
      }, 250);
    } catch (err) { pb.style.display = 'none'; btn.disabled = false; setSt('Error: ' + err.message, 'er'); }
  }, 50);
}

// ── RESULTS ──
const fm = n => '$' + Math.abs(n).toLocaleString('en-AU', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const fms = n => (n >= 0 ? '+' : '−') + fm(Math.abs(n));
const pc = n => (n * 100).toFixed(0) + '%';

function groupBy(data, keyFn) {
  const m = {};
  data.forEach(r => {
    const k = keyFn(r);
    if (!m[k]) m[k] = { count: 0, gross: 0, sav: 0 };
    m[k].count++; m[k].gross += r.gross; m[k].sav += r.sav;
  });
  return Object.entries(m).sort((a, b) => b[1].sav - a[1].sav);
}

function summaryRows(entries, cols) {
  const totCount = entries.reduce((s, [, v]) => s + v.count, 0);
  const totGross = entries.reduce((s, [, v]) => s + v.gross, 0);
  const totSav   = entries.reduce((s, [, v]) => s + v.sav, 0);
  const rows = entries.map(([k, v]) => `<tr>
    ${cols(k, v)}
    <td style="text-align:right">${v.count.toLocaleString()}</td>
    <td style="text-align:right">${fm(v.gross)}</td>
    <td style="text-align:right;font-weight:600" class="${v.sav >= 0 ? 'sp' : 'sn'}">${fms(v.sav)}</td>
  </tr>`).join('');
  const foot = `<tr style="border-top:2px solid var(--border);font-weight:700">
    <td colspan="${cols.colSpan || 1}" style="font-weight:700">Total</td>
    <td style="text-align:right">${totCount.toLocaleString()}</td>
    <td style="text-align:right">${fm(totGross)}</td>
    <td style="text-align:right;font-weight:700" class="${totSav >= 0 ? 'sp' : 'sn'}">${fms(totSav)}</td>
  </tr>`;
  return rows + foot;
}

function buildResults(data) {
  document.getElementById('rEmpty').style.display = 'none';
  document.getElementById('rContent').style.display = 'block';

  const ts  = data.reduce((s, r) => s + r.sav, 0);
  const tg  = data.reduce((s, r) => s + r.gross, 0);
  const ad  = data.length ? data.reduce((s, r) => s + r.disc, 0) / data.length : 0;
  const rt  = new Set(data.map(r => r.route)).size;
  const neg = data.filter(r => r.sav < 0);
  const unmatched = data.filter(r => r.disc === 0 && r.tv === 'D');
  const unmatchedClasses = [...new Set(unmatched.map(r => r.bc))].filter(Boolean).sort();

  document.getElementById('modeBox').innerHTML = newCust
    ? `<div style="background:var(--red-light);border:1.5px solid var(--brand-pink);border-radius:var(--radius);padding:10px 16px;font-size:13px;color:var(--brand-pink);font-weight:600;display:flex;align-items:center;gap:8px;">🆕 New Qantas Customer mode — deal savings calculated as Gross Fare × Discount Rate (no original fare uplift)</div>`
    : `<div style="background:var(--green-light);border:1.5px solid var(--brand-teal);border-radius:var(--radius);padding:10px 16px;font-size:13px;color:var(--brand-teal);font-weight:600;display:flex;align-items:center;gap:8px;">✅ Existing contract mode — deal savings = Original Fare − Gross Fare</div>`;
  const savLabel = newCust ? 'Savings off paid fare' : 'Total deal savings';
  const savNote  = newCust ? 'New customer — discount off gross fare' : 'Net across all segments';

  document.getElementById('mets').innerHTML = `
    <div class="met"><div class="ml">${savLabel}</div><div class="mv" style="color:var(--brand-pink)">${fm(ts)}</div><div class="ms">${savNote}</div></div>
    <div class="met"><div class="ml">Total gross fares</div><div class="mv">${fm(tg)}</div><div class="ms">QF original tickets</div></div>
    <div class="met"><div class="ml">Segments analysed</div><div class="mv">${data.length.toLocaleString()}</div><div class="ms">${neg.length} refunds/cancellations</div></div>
    <div class="met"><div class="ml">Avg discount rate</div><div class="mv">${pc(ad)}</div></div>
    <div class="met"><div class="ml">Unique routes</div><div class="mv">${rt}</div></div>`;

  // Warnings
  const warns = [];
  if (neg.length) warns.push(`<div style="background:var(--amber-light);border:1px solid var(--amber-text);border-radius:var(--radius);padding:10px 14px;margin-bottom:8px;font-size:13px;color:var(--amber-text)">
    ⚠️ <strong>${neg.length} segments have negative deal savings</strong> — these are refunds or cancellations where the TTV is negative. They are included in the net total, which is correct.
  </div>`);
  if (unmatchedClasses.length) warns.push(`<div style="background:var(--amber-light);border:1px solid var(--amber-text);border-radius:var(--radius);padding:10px 14px;font-size:13px;color:var(--amber-text)">
    ⚠️ <strong>${unmatched.length} domestic segments have booking class${unmatchedClasses.length > 1 ? 'es' : ''} not in the discount table: <span style="font-family:var(--mono)">${unmatchedClasses.join(', ')}</span></strong> — a 0% discount was applied. Add these classes to the discount rates panel if they should be discounted.
  </div>`);
  const wb = document.getElementById('warnBox');
  wb.style.display = warns.length ? 'block' : 'none';
  wb.innerHTML = warns.join('');

  // By booking class
  const byClass = groupBy(data, r => r.bc + '||' + r.tv);
  const classCols = (k, v) => {
    const [bc, tv] = k.split('||');
    const discPct = data.find(r => r.bc === bc && r.tv === tv)?.disc || 0;
    return `<td style="font-family:var(--mono);font-weight:600">${bc}</td><td>${tv === 'D' ? 'Domestic' : tv === 'I' ? 'International' : tv}</td><td style="text-align:right;color:var(--green-text)">${pc(discPct)}</td>`;
  };
  classCols.colSpan = 3;
  // Re-add header col for discount
  document.getElementById('tblClass').innerHTML = summaryRows(byClass, classCols);
  // Fix header to include discount col
  document.querySelector('#tblClass').closest('table').querySelector('thead tr').innerHTML =
    '<th>Class</th><th>Type</th><th style="text-align:right">Discount</th><th style="text-align:right">Segments</th><th style="text-align:right">Gross fares</th><th style="text-align:right">Deal savings</th>';

  // By cabin
  const byCabin = groupBy(data, r => r.cabin || 'Unknown');
  const cabinCols = (k) => `<td>${k}</td>`;
  cabinCols.colSpan = 1;
  document.getElementById('tblCabin').innerHTML = summaryRows(byCabin, cabinCols);

  // By route (top 15)
  const byRoute = groupBy(data, r => r.route);
  const top15 = byRoute.slice(0, 15);
  const routeCols = (k) => `<td style="font-family:var(--mono)">${k}</td>`;
  routeCols.colSpan = 1;
  document.getElementById('tblRoute').innerHTML = summaryRows(top15, routeCols);
}

function doExport() {
  if (!results.length) return;
  const h = ['Airline','Traveller','Route','Cabin','Booking Class','Travel Type','Gross Fare','QF Discount %','Original Fare','Deal Savings','Tax GST'];
  const rows = results.map(r => [r.al, r.trav, r.route, r.cabin, r.bc, r.tv, r.gross.toFixed(2), (r.disc*100).toFixed(1), r.orig.toFixed(2), r.sav.toFixed(2), r.gst.toFixed(2)]);
  const csv = [h, ...rows].map(r => r.map(v => '"' + String(v).replace(/"/g, '""') + '"').join(',')).join('\n');
  document.getElementById('exportTextarea').value = csv;
  document.getElementById('copyNote').textContent = '';
  document.getElementById('exportModal').classList.add('vis');
  setTimeout(() => document.getElementById('exportTextarea').select(), 100);
}

function closeExport() {
  document.getElementById('exportModal').classList.remove('vis');
}

function closeExportIfBg(e) {
  if (e.target === document.getElementById('exportModal')) closeExport();
}

function copyExport() {
  const ta = document.getElementById('exportTextarea');
  ta.select();
  navigator.clipboard.writeText(ta.value).then(() => {
    const note = document.getElementById('copyNote');
    note.textContent = '✅ Copied! Paste into Excel or a .csv file.';
    note.style.color = 'var(--brand-teal)';
    setTimeout(() => note.textContent = '', 3000);
  }).catch(() => {
    document.getElementById('copyNote').textContent = 'Use Ctrl+A then Ctrl+C to copy';
  });
}

// ── NAV ──
function goTab(t, btn) {
  document.querySelectorAll('.tab').forEach(x => x.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(x => x.classList.remove('active'));
  if (btn) btn.classList.add('active');
  document.getElementById('tab-' + t).classList.add('active');
}
function goTabDirect(t) {
  const n = ['upload', 'results', 'how'];
  document.querySelectorAll('.tab').forEach((x, i) => x.classList.toggle('active', n[i] === t));
  document.querySelectorAll('.panel').forEach((x, i) => x.classList.toggle('active', n[i] === t));
}
function setSt(m, c) { const e = document.getElementById('stMsg'); e.textContent = m; e.className = 'st ' + (c || ''); }
function copyLink() {
  navigator.clipboard.writeText(window.location.href).then(() => {
    document.getElementById('sToast').textContent = 'Link copied!';
    setTimeout(() => document.getElementById('sToast').textContent = '', 2500);
  }).catch(() => {
    document.getElementById('sToast').textContent = 'Copy the URL from your browser address bar';
    setTimeout(() => document.getElementById('sToast').textContent = '', 3000);
  });
}

renderRates();
